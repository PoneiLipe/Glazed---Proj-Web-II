<%- include('partials/header', { title }) %>

<section class="hero">
  <h1>Cadastro de Usuário</h1>
  <p>Crie sua conta para participar do monitoramento de reciclagem.</p>
</section>

<section class="auth-box card">
  <div id="mensagemCadastro"></div>
  <form id="cadastroForm">
    <div class="form-group">
      <label for="nome">Nome completo</label>
      <input type="text" id="nome" name="nome" required>
    </div>
    <div class="form-group">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" required>
    </div>
    <div class="form-group">
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" minlength="6" required>
    </div>
    <button class="btn btn-primary" type="submit">Cadastrar</button>
    <a class="btn btn-secondary" href="/login">Já tenho conta</a>
  </form>
</section>

<script>
document.getElementById('cadastroForm').addEventListener('submit', async (event) => {
  event.preventDefault();
  const box = document.getElementById('mensagemCadastro');
  box.innerHTML = '';
  try {
    const dados = Object.fromEntries(new FormData(event.target).entries());
    const resposta = await postJSON('/api/auth/cadastro', dados);
    salvarUsuario(resposta.usuario);
    box.innerHTML = '<div class="alert alert-success">Cadastro realizado com sucesso. Redirecionando...</div>';
    setTimeout(() => window.location.href = '/', 800);
  } catch (error) {
    box.innerHTML = `<div class="alert alert-error">${error.message}</div>`;
  }
});
</script>
<%- include('partials/footer') %>
