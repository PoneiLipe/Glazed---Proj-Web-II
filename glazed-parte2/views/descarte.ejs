<%- include('partials/header', { title }) %>

<section class="hero">
  <h1>Registrar Descarte</h1>
  <p>Registre materiais enviados para reciclagem e visualize o impacto ambiental estimado antes do envio.</p>
</section>

<section class="section">
  <div class="form-container">
    <div id="mensagemDescarte"></div>
    <form id="descarteForm">
      <div class="form-group">
        <label for="ponto">Ponto de coleta</label>
        <select id="ponto" required><option value="">Carregando pontos...</option></select>
      </div>
      <div class="grid grid-2">
        <div class="form-group">
          <label for="categoria">Categoria</label>
          <select id="categoria" required>
            <option value="">Selecione</option>
            <option>Plástico</option><option>Vidro</option><option>Metal</option><option>Papel</option>
            <option>Orgânico</option><option>Eletrônico</option><option>Óleo</option><option>Bateria</option>
          </select>
        </div>
        <div class="form-group">
          <label for="quantidadeKg">Quantidade em kg</label>
          <input type="number" id="quantidadeKg" min="0.01" step="0.01" required>
        </div>
      </div>
      <div class="form-group">
        <label for="observacoes">Observações</label>
        <textarea id="observacoes" placeholder="Ex.: garrafas PET, papelão, latas..."></textarea>
      </div>
      <div class="chart-container" id="impactoPreview">
        <h3>Impacto estimado</h3>
        <p>CO₂ evitado: <strong id="co2Preview">0 kg</strong></p>
        <p>Árvores preservadas: <strong id="arvoresPreview">0</strong></p>
        <p>Água economizada: <strong id="aguaPreview">0 L</strong></p>
      </div>
      <button class="btn btn-primary" type="submit">Registrar descarte</button>
    </form>
  </div>
</section>

<script src="/js/descarte.js"></script>
<%- include('partials/footer') %>
